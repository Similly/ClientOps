APP_DOMAIN="clientops.example.com"

POSTGRES_DB="clientops"
POSTGRES_USER="clientops"
POSTGRES_PASSWORD="change-this-postgres-password"

DATABASE_URL="postgresql://clientops:change-this-postgres-password@db:5432/clientops?schema=public"
NEXTAUTH_URL="https://clientops.example.com"
NEXTAUTH_SECRET="change-this-to-a-long-random-secret"
UPLOAD_DIR="uploads"
MAX_UPLOAD_MB="10"

